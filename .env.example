# Logistikos Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection string with PostGIS adapter
# Format: postgis://username:password@host:port/database
# For Docker development environment, use:
DATABASE_URL=postgis://postgres:postgres@localhost:5432/logistikos_development

# For test environment, override with:
# DATABASE_URL=postgis://postgres:postgres@localhost:5432/logistikos_test

# Individual PostgreSQL environment variables for Docker Compose
# These are used by the postgres service in docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logistikos_development


# ============================================================================
# External Services
# ============================================================================

# Mapbox API token for map rendering and geocoding
# Required for: map display, address geocoding, route visualization
# Get your token at: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google OAuth credentials for sign-in
# Optional for MVP (can use email/password authentication)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# Anthropic Claude API key for AI features
# Required for: NL order parsing, smart pricing, ETA narratives
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here


# ============================================================================
# Payment Configuration
# ============================================================================

# Payment gateway selection
# Options: "mock" (development/MVP), "stripe" (production)
# Default: mock
PAYMENT_GATEWAY=mock

# Stripe configuration (only required when PAYMENT_GATEWAY=stripe)
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Platform fee percentage for driver earnings
# Default: 15 (represents 15%)
PLATFORM_FEE_PERCENT=15


# ============================================================================
# Rails Configuration
# ============================================================================

# Rails encryption key for sessions and credentials
# Generate with: bin/rails secret
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_rails_secret

# Environment designation
# Options: development, test, production
RAILS_ENV=development


# ============================================================================
# Security Notes
# ============================================================================
# - STRIPE_SECRET_KEY is stored in Rails credentials (bin/rails credentials:edit), NOT here
# - Never commit .env file with real credentials
# - Use strong passwords for production databases
# - Rotate secrets regularly in production
# - Consider using Docker secrets for production deployments
